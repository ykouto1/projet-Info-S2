#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#define MAX_ACCOUNTS 100

typedef struct {
    int id;
    char name[100];
    float balance;
} Account;

Account accounts[MAX_ACCOUNTS];
int accountCount = 0;

void createAccount(char *name, float initialBalance) {
    if (accountCount >= MAX_ACCOUNTS) {
        printf("Maximum number of accounts reached.\n");
        return;
    }
    accounts[accountCount].id = accountCount + 1;
    strcpy(accounts[accountCount].name, name);
    accounts[accountCount].balance = initialBalance;
    accountCount++;
    printf("Account created successfully!\n");
}

void deposit(int id, float amount) {
    for (int i = 0; i < accountCount; i++) {
        if (accounts[i].id == id) {
            accounts[i].balance += amount;
            printf("Deposited %.2f to account %d. New balance: %.2f\n", amount, id, accounts[i].balance);
            return;
        }
    }
    printf("Account not found.\n");
}

void withdraw(int id, float amount) {
    for (int i = 0; i < accountCount; i++) {
        if (accounts[i].id == id) {
            if (accounts[i].balance >= amount) {
                accounts[i].balance -= amount;
                printf("Withdrew %.2f from account %d. New balance: %.2f\n", amount, id, accounts[i].balance);
            } else {
                printf("Insufficient balance.\n");
            }
            return;
        }
    }
    printf("Account not found.\n");
}

void displayBalance(int id) {
    for (int i = 0; i < accountCount; i++) {
        if (accounts[i].id == id) {
            printf("Account %d balance: %.2f\n", id, accounts[i].balance);
            return;
        }
    }
    printf("Account not found.\n");
}

int main() {
    int choice, id;
    char name[100];
    float amount;

    while (1) {
        printf("\nBank Simulator\n");
        printf("1. Create Account\n");
        printf("2. Deposit\n");
        printf("3. Withdraw\n");
        printf("4. Display Balance\n");
        printf("5. Exit\n");
        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                printf("Enter name: ");
                scanf("%s", name);
                printf("Enter initial balance: ");
                scanf("%f", &amount);
                createAccount(name, amount);
                break;
            case 2:
                printf("Enter account ID: ");
                scanf("%d", &id);
                printf("Enter amount to deposit: ");
                scanf("%f", &amount);
                deposit(id, amount);
                break;
            case 3:
                printf("Enter account ID: ");
                scanf("%d", &id);
                printf("Enter amount to withdraw: ");
                scanf("%f", &amount);
                withdraw(id, amount);
                break;
            case 4:
                printf("Enter account ID: ");
                scanf("%d", &id);
                displayBalance(id);
                break;
            case 5:
                exit(0);
            default:
                printf("Invalid choice. Please try again.\n");
        }
    }

    return 0;
}
